export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const { company_name } = req.body;

  try {
    const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${process.env.OPENROUTER_API_KEY}`, // المفتاح هنا آمن 100%
      },
      body: JSON.stringify({
        model: 'openrouter/auto',
        messages: [{ 
          role: 'user', 
          content: `Return ONLY a JSON object about company "${company_name}": {"country":"country in Arabic","city":"city in Arabic","contact_name":"known contact or empty","annual_sales":"sales volume or empty","main_products":"main products in Arabic comma separated","notes":"one line in Arabic"}` 
        }],
      })
    });

    const data = await response.json();
    res.status(200).json(data);
  } catch (error) {
    res.status(500).json({ error: 'Failed to fetch AI' });
  }
}